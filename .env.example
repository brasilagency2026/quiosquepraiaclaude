# ═══════════════════════════════════════════════════
# PraiaApp — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ═══════════════════════════════════════════════════

# ── Convex ──────────────────────────────────────────
# Obtenu après "npx convex dev" ou "npx convex deploy"
VITE_CONVEX_URL=https://xxxxx.convex.cloud

# ── Clerk ───────────────────────────────────────────
# Obtenu sur clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# ── Chiffrement des clés de paiement ───────────────
# Générer avec: openssl rand -base64 32
# À configurer aussi dans Convex Dashboard → Settings → Environment Variables
ENCRYPTION_SECRET=votre-cle-aleatoire-de-32-caracteres-minimum

# ── Super Admin ─────────────────────────────────────
# Votre Clerk User ID (visible sur clerk.com → Users)
VITE_SUPER_ADMIN_ID=user_xxxxxxxxxxxxxxxxxx

# ── URLs (pour les webhooks) ─────────────────────────
# URL de votre frontend Vercel (sans slash final)
FRONTEND_URL=https://praiapp.vercel.app

# ── MercadoPago (optionnel — configuré par chaque gestor) ──
# Ces clés sont configurées PAR QUIOSQUE dans le panel Admin
# NE PAS mettre ici les clés des quiosques
# Clés de test pour le développement local uniquement:
# VITE_MP_PUBLIC_KEY_DEV=TEST-xxxxxxxx
# MP_ACCESS_TOKEN_DEV=TEST-xxxxxxxx

# ═══════════════════════════════════════════════════
# IMPORTANT — Variables à configurer dans Convex Dashboard:
# → dashboard.convex.dev → Votre projet → Settings → Environment Variables
#
# ENCRYPTION_SECRET=votre-cle-aleatoire-32-chars
# CONVEX_SITE_URL=https://xxxxx.convex.site
# FRONTEND_URL=https://praiapp.vercel.app
# ═══════════════════════════════════════════════════
